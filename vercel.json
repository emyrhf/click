{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "^/public/(.+)$",
      "dest": "/api/static.php"
    },
    {
      "src": "^/$",
      "dest": "/api/visao/index.php"
    },
    {
      "src": "^/visao/([a-zA-Z0-9_-]+)/?$",
      "dest": "/api/visao/$1.php"
    },
    {
      "src": "^/processadores/([a-zA-Z0-9_-]+)/?$",
      "dest": "/api/processadores/$1.php"
    }
  ]
}

{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/",
      "dest": "/api/visao/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/visao/index.php"
    }
  ]
}

{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    },
    {
      "src": "/cadastro",
      "dest": "/api/cadastro.php"
    },
    {
      "src": "/((?!public|api).* )",
      "dest": "/api/index.php"
    }
  ]
}

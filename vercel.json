{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/(css|js|imgs)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    },
    {
      "src": "/cadastro",
      "dest": "/api/cadastro.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
